# Copy to ".env" and adjust.
#
# For DEVICE testing against your LOCAL dev server, point this at your PC's LAN
# IP (NOT localhost — that resolves to the phone itself). Your machine's IP was
# detected as 192.168.1.15 and the Next dev server listens on :3000.
#
# Phone and PC must be on the same Wi-Fi.
EXPO_PUBLIC_API_URL=http://192.168.1.15:3000

# For production, leave this unset — the app falls back to expo.extra.apiBaseUrl
# in app.json (https://prebuildapps.com). NOTE: the /api/mobile/v1/* endpoints
# must be DEPLOYED there first; they currently exist only in your local build.
